# Copia este fichero como .env y rellena tus credenciales de Alpaca
# Obtén tus API keys en: https://alpaca.markets
# Profile Settings → Manage Accounts → Paper Accounts → API Keys

# Paper Trading (simulado, dinero ficticio) - recomendado para empezar
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Live Trading (dinero real) - descomentar solo cuando estés seguro
# ALPACA_LIVE_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxx
# ALPACA_LIVE_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
